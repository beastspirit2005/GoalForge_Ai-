# PostgreSQL (required for Vercel / Render — SQLite does not persist on serverless)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/goalforge
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/goalforge

SECRET_KEY=change-me-in-production
GEMINI_API_KEY=

# Vercel frontend URL(s), comma-separated (for CORS when frontend and API are on different hosts)
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-main.vercel.app
# FRONTEND_URL=https://your-app.vercel.app

DEBUG=false
